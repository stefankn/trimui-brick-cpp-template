# TrimUI Brick Configuration
# Copy this file to .env and update with your settings

# Project name (used by both Makefile and deploy script)
PROJECT_NAME=my-brick-app

# PAK name (defaults to PROJECT_NAME.pak if not set)
PAK_NAME=my-brick-app.pak

# Brick device IP address (check in network settings)
BRICK_IP=192.168.0.142

# Brick SSH password (default is "tina")
BRICK_PASS=tina

# FTP credentials (default minui:minui)
FTP_USER=minui:minui
